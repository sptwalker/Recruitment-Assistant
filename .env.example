APP_ENV=local
# 留空 → 本地 SQLite（data/resume_archive.db）；多用户部署设 PG DSN：
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/recruitment
DATABASE_URL=
PLAYWRIGHT_HEADLESS=false
CRAWLER_MIN_INTERVAL_SECONDS=8
CRAWLER_MAX_INTERVAL_SECONDS=30
CRAWLER_MAX_RESUMES_PER_TASK=50
EXPORT_DIR=data/exports
ATTACHMENT_DIR=data/attachments
BROWSER_STATE_DIR=data/browser_state
SNAPSHOT_DIR=data/snapshots
LOG_LEVEL=INFO

# M2 认证（切勿把真实值提交到 git）：
FRONTEND_ORIGIN=http://localhost:5173
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:8000/auth/feishu/callback
JWT_SECRET=change-me-to-a-random-32+-char-secret

